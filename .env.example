# Local development defaults — copy to .env or export in your shell.
PORT=3016
NODE_ENV=development

# Dev-only auth bypass: accepts tokens of the form dev:<user_id>:<room_id>.
# The server REFUSES to boot with this set when NODE_ENV=production.
DEV_ALLOW_UNSIGNED=1

# Fill the room with a server-side bot after 5s so one dev can play alone.
BOT_FILL=1

# --- Platform integration (production values shown) ---
SERVICE_ID=tilt-royale
API_URL=https://mobile.mongolai.mn
JWKS_URL=https://mobile.mongolai.mn/.well-known/jwks.json

# Result-webhook signing. key_id + shared_secret must match the service's
# registry `realtime.signing` config. Generate: openssl rand -base64 48 | tr '+/' '-_'
SIGNING_KEY_ID=tilt-royale-key-1
SIGNING_SECRET=change-me
